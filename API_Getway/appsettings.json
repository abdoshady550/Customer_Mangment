{
  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "Customer_Mangment-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "Customer_Mangment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7279"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
